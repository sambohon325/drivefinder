# Copy this to .env (local) or set these as Coolify environment variables.

# Required: Google AI Studio key, used for both chat extraction and image generation
GEMINI_API_KEY=

# Required: any long random string, used to sign session cookies and passwords
SECRET_KEY=change-me-to-something-random

# "production" enables secure (HTTPS-only) cookies. Keep as "development" for local testing.
ENVIRONMENT=development

# Admin tool (/admin) — reviews and lets you delete cached vehicle renders.
# Leave ADMIN_PASSWORD blank to disable the admin tool entirely.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Bump this any time chat_logic.py's image prompts change meaningfully —
# it invalidates every previously cached render so old (possibly wrong)
# images can never be served again.
IMAGE_PROMPT_VERSION=v3

# Region availability (which US states / Canadian provinces DriveFinder is
# open in) is managed at /admin, not via environment variables — it's
# seeded all-enabled on first boot and toggled from there.

# Background cache pre-warming: quietly generates renders the current
# inventory needs before anyone asks for them. Paced deliberately slow —
# one render per interval, not a burst. New renders land in the "Unprocessed"
# review queue at /admin either way; they're already live, this is just for
# your review.
PREWARM_ENABLED=true
PREWARM_INTERVAL_SECONDS=45

# Restricts pre-warming to certain hours so it doesn't compete with live
# testing/traffic for API quota. Defaults to midnight-7am Central — set
# RESTRICT_HOURS=false to run all day instead (the original behavior).
# Note: Gemini's daily quota (RPD) resets at midnight *Pacific* time, not
# whatever timezone you set here — that's 2am Central.
PREWARM_RESTRICT_HOURS=true
PREWARM_ACTIVE_START_HOUR=0
PREWARM_ACTIVE_END_HOUR=7
PREWARM_TIMEZONE=America/Chicago
